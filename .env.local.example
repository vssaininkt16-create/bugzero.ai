# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# For server-side admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Razorpay (VAPT ₹999 payments) ───────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here
# Optional: webhook secret for /api/vapt/webhook
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Admin Dashboard (NextAuth) ──────────────────────────────────────────────
NEXTAUTH_URL=https://bugzero.solutions
NEXTAUTH_SECRET=your-random-secret-min-32-chars-here
ADMIN_EMAIL=admin@bugzero.solutions
ADMIN_PASSWORD=your-strong-admin-password-here

# ─── AI Chat ─────────────────────────────────────────────────────────────────
# Optional — uses free Pollinations.ai fallback if not set
# Get free key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ─── OWASP ZAP (optional deep scanner) ───────────────────────────────────────
# Leave BLANK to use the built-in scanner (default)
# ZAP_API_URL=http://localhost:8080
# ZAP_API_KEY=your-zap-api-key-here

# ─── Email notifications (optional) ──────────────────────────────────────────
ADMIN_EMAIL_NOTIFY=admin@bugzero.solutions
