# ─── Supabase (User Auth / Dashboard / Contact Form) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: for server-side admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin Dashboard (NextAuth) ──────────────────────────────────────────────
# Set NEXTAUTH_URL to your production domain (required in production)
NEXTAUTH_URL=https://bugzero.solutions
NEXTAUTH_SECRET=your-random-secret-min-32-chars-here

# Admin login credentials for /admin
ADMIN_EMAIL=admin@bugzero.solutions
ADMIN_PASSWORD=your-strong-admin-password-here

# ─── AI Chat (OpenRouter) ────────────────────────────────────────────────────
# Get free API key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ─── Optional: Email notifications ──────────────────────────────────────────
ADMIN_EMAIL_NOTIFY=admin@bugzero.solutions
